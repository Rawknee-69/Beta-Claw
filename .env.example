ANTHROPIC_API_KEY=                 # Anthropic Claude
OPENAI_API_KEY=                    # OpenAI
OPENROUTER_API_KEY=                # OpenRouter (200+ models)

# Channels (enable the ones you want)
TELEGRAM_BOT_TOKEN=                # Get from @BotFather on Telegram
DISCORD_BOT_TOKEN=                 # Get from discord.com/developers

# Web Search (optional, enables web_search tool)
BRAVE_API_KEY=                     # brave.com/search/api
SERPER_API_KEY=                    # serper.dev

# Behaviour
TRIGGER_WORD=@Andy                 # Trigger word for groups

